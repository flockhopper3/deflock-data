{
  "version": 3,
  "source": {
    "id": "cameras",
    "type": "vector",
    "url": "https://tiles.dontgetflocked.com/cameras.json"
  },
  "layers": [
    {
      "id": "direction-cones",
      "type": "fill",
      "source": "direction-cones",
      "minzoom": 12,
      "paint": {
        "fill-color": "#ef4444",
        "fill-opacity": 0.35
      }
    },
    {
      "id": "direction-cones-outline",
      "type": "line",
      "source": "direction-cones",
      "minzoom": 12,
      "paint": {
        "line-color": "#dc2626",
        "line-width": 2,
        "line-opacity": 0.7
      }
    },
    {
      "id": "camera-heat",
      "type": "heatmap",
      "source": "cameras",
      "source-layer": "cameras",
      "maxzoom": 13,
      "paint": {
        "heatmap-weight": 1,
        "heatmap-intensity": [
          "interpolate", ["linear"], ["zoom"],
          0, 1,
          9, 3,
          13, 4
        ],
        "heatmap-radius": [
          "interpolate", ["exponential", 1.5], ["zoom"],
          0, 10,
          4, 18,
          8, 26,
          11, 32,
          13, 40
        ],
        "heatmap-color": [
          "interpolate", ["linear"], ["heatmap-density"],
          0, "rgba(0,0,0,0)",
          0.15, "rgba(69,10,10,0.45)",
          0.35, "#7f1d1d",
          0.55, "#b91c1c",
          0.75, "#ef4444",
          0.92, "#f97316",
          1, "#fde047"
        ],
        "heatmap-opacity": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.85,
          10, 0.85,
          11, 0.7,
          13, 0
        ]
      }
    },
    {
      "id": "camera-point",
      "type": "circle",
      "source": "cameras",
      "source-layer": "cameras",
      "minzoom": 11,
      "paint": {
        "circle-color": "#dc2626",
        "circle-radius": 6,
        "circle-stroke-width": 2,
        "circle-stroke-color": "#fca5a5",
        "circle-stroke-opacity": [
          "interpolate", ["linear"], ["zoom"],
          11, 0,
          13, 1
        ],
        "circle-opacity": [
          "interpolate", ["linear"], ["zoom"],
          11, 0,
          13, 1
        ]
      }
    },
    {
      "id": "camera-glow",
      "type": "circle",
      "source": "cameras",
      "source-layer": "cameras",
      "minzoom": 11,
      "paint": {
        "circle-color": "#ef4444",
        "circle-radius": [
          "interpolate", ["linear"], ["zoom"],
          11, 6,
          14, 14,
          16, 18
        ],
        "circle-opacity": [
          "interpolate", ["linear"], ["zoom"],
          11, 0,
          13, 0.3
        ],
        "circle-blur": 0.6
      }
    }
  ],
  "cones": {
    "radiusFt": 150,
    "spreadDeg": 50,
    "arcSegments": 8
  },
  "palette": {
    "camera": "#ef4444",
    "camera-dark": "#dc2626",
    "camera-light": "#fca5a5",
    "route-privacy": "#3b82f6",
    "route-direct": "#f97316",
    "origin": "#22c55e",
    "destination": "#ef4444"
  }
}
